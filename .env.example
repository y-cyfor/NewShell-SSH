# NewShell Server Environment Variables
# Copy this file to .env and fill in your values

# Server port (default: 29800)
NEWSHELL_PORT=29800

# JWT secret for token signing (REQUIRED - generate with: openssl rand -hex 32)
NEWSHELL_JWT_SECRET=

# Encryption key for sensitive data (REQUIRED - generate with: openssl rand -hex 32)
NEWSHELL_ENCRYPTION_KEY=

# Your domain name (for nginx SSL)
DOMAIN=your-domain.com
